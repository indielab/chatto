# Dev-shell image for containerized frontend development.
# Mount or sync source into running containers to avoid rebuilding on every
# code change.

FROM node:22-alpine
RUN corepack enable pnpm
WORKDIR /app

# Layer 1: deps (cached unless lockfile changes)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY apps/frontend/package.json apps/frontend/package.json
RUN pnpm config set store-dir /pnpm-store && pnpm install --frozen-lockfile --filter chatto-frontend...

# Layer 2: source
COPY apps/frontend apps/frontend
WORKDIR /app/apps/frontend
